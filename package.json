{
  "name": "tertiumnon-github-io",
  "version": "1.61.6",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "gh:pages:build": "bun ./scripts/gh-pages/gh-pages--build/gh-pages--build.ts",
    "post:create": "bun ./scripts/post/create/create.ts",
    "post:list:create": "bun ./scripts/post/list--create/list--create.ts",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint:fix": "bunx rome format --write src && bunx rome check src --apply",
    "lint:ts:check": "tsc --noEmit",
    "release": "bun node_modules/@tertium/js/scripts/release/release.ts",
    "release:patch": "bun run release patch",
    "release:minor": "bun run release minor",
    "release:major": "bun run release major"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.26",
    "@angular/common": "^20.3.26",
    "@angular/compiler": "^20.3.26",
    "@angular/core": "^20.3.26",
    "@angular/forms": "^20.3.26",
    "@angular/platform-browser": "^20.3.26",
    "@angular/platform-browser-dynamic": "^20.3.26",
    "@angular/router": "^20.3.26",
    "@tertium/css": "^1.4.1",
    "@tertium/js": "^2.1.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^29.1.1",
    "marked": "^5.1.2",
    "rxjs": "^7.8.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2003.32",
    "@angular-devkit/core": "^20.3.32",
    "@angular-devkit/schematics": "^20.3.32",
    "@angular/build": "^20.3.32",
    "@angular/cli": "^20.3.32",
    "@angular/compiler-cli": "^20.3.26",
    "@types/node": "^18.19.130",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.5.4",
    "postcss": "^8.5.21",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "rome": "^12.1.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ],
  "overrides": {
    "tar": "^7.5.20"
  }
}
