{
  "name": "tertiumnon-github-io",
  "version": "1.60.23",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "gh:pages:build": "bun ./scripts/gh-pages/gh-pages--build/gh-pages--build.ts",
    "post:create": "bun ./scripts/post/create/create.ts",
    "post:list:create": "bun ./scripts/post/list--create/list--create.ts",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint:fix": "bunx rome format --write src && bunx rome check src --apply",
    "lint:ts:check": "tsc --noEmit",
    "release": "bun node_modules/@tertium/js/scripts/release/release.ts",
    "release:patch": "bun run release patch",
    "release:minor": "bun run release minor",
    "release:major": "bun run release major"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.2",
    "@angular/common": "^20.3.2",
    "@angular/compiler": "^20.3.2",
    "@angular/core": "^20.3.2",
    "@angular/forms": "^20.3.2",
    "@angular/platform-browser": "^20.3.2",
    "@angular/platform-browser-dynamic": "^20.3.2",
    "@angular/router": "^20.3.2",
    "@tertium/css": "^1.4.1",
    "@tertium/js": "^2.0.0",
    "highlight.js": "^11.8.0",
    "jsdom": "^29.1.1",
    "marked": "^5.1.0",
    "rxjs": "^7.8.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.2.0",
    "update": "^0.7.4",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2003.3",
    "@angular-devkit/core": "^20.3.3",
    "@angular-devkit/schematics": "^20.3.3",
    "@angular/build": "^20.3.3",
    "@angular/cli": "^20.3.3",
    "@angular/compiler-cli": "^20.3.2",
    "@types/node": "^18.17.15",
    "@vitest/ui": "^1.0.4",
    "autoprefixer": "^10.4.15",
    "postcss": "^8.4.29",
    "vitest": "^1.0.4",
    "@vitest/coverage-v8": "^1.0.4",
    "rome": "^12.1.3",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.8.3"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
