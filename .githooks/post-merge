#!/usr/bin/env bash
# Post-merge hook: update articles after pulling changes

set -e

echo "📚 Updating article list..."
bun run post:list:create

# Only commit if there are changes
if ! git diff --quiet src/assets/posts.json; then
  git add src/assets/posts.json
  git commit -m "docs: update article list" --no-verify
fi

echo "✅ Article list updated!"
