#!/usr/bin/env bash
# Pre-commit hook: lint and test before committing

set -e

echo "🔍 Running pre-commit checks..."

# Run linting
echo "  → Checking TypeScript..."
bun run lint:ts:check || exit 1

# Run tests
echo "  → Running tests..."
bun test --run || exit 1

echo "✅ Pre-commit checks passed!"
